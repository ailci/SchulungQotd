@model SchulungMvc.Common.ViewModels.QotdSummaryViewModel

<div class="row">
    <div class="col-6">
        <div class="info-box">
            <span class="info-box-icon bg-info"><i class="bi bi-person-circle"></i></span>

            <div class="info-box-content">
                <span class="info-box-text">Autoren</span>
                <span class="info-box-number">@Model.AuthorsQuantity</span>
            </div>
            <!-- /.info-box-content -->
        </div>
    </div>
    <div class="col-6">
        <div class="info-box">
            <span class="info-box-icon bg-success"><i class="bi bi-chat-quote"></i></span>

            <div class="info-box-content">
                <span class="info-box-text">Sprüche</span>
                <span class="info-box-number">@Model.AuthorsQuantity</span>
            </div>
            <!-- /.info-box-content -->
        </div>
    </div>
</div>