@page
@model SchulungQotd.Mvc.Pages.Quote.IndexModel


<table class="table table-hover table-sm">
    <thead>
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Quotes.First().QuoteText)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Quotes.First().AuthorName)
        </th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Quotes)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.QuoteText)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AuthorName)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-warning"><i class="bi bi-pencil-fill"></i></a> |
                <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-info"><i class="bi bi-info-circle-fill"></i></a> |
                <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-danger"><i class="bi bi-trash"></i></a>
            </td>
        </tr>
    }
    </tbody>
</table>
